{
  "version": 2,
  "buildCommand": "npm install --legacy-peer-deps && npm run build || true",
  "installCommand": "npm install --legacy-peer-deps",
  "builds": [
    {
      "src": "server.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.mjs"
    }
  ]
}
